# ── LangSmith (Tracing) ─────────────────────────────────────────────────────
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=music-composer-assistant
# Si estás en EU: LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com

# ── Azure AI Foundry ────────────────────────────────────────────────────────
# Encuéntralo en: Azure Portal → tu recurso → Keys and Endpoint
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Nombre del deployment en Azure Foundry (el que pusiste al desplegar el modelo)
# Ejemplo: "gpt-4o", "my-gpt4o-deployment", etc.
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# ── SerpAPI (búsqueda web) ──────────────────────────────────────────────────
# Consíguelo en: https://serpapi.com/ (100 búsquedas/mes gratis)
SERPAPI_API_KEY=your_serpapi_api_key_here
